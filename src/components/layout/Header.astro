---
import logo from "../../assets/logo.png";
---

<header
  id="siteHeader"
  class="fixed top-0 left-0 z-50 w-full bg-bg transition-transform duration-300"
>
  <!-- =====================
       TOPBAR
       ===================== -->
  <div class="border-b border-border bg-bg-muted text-sm">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2">
      <div class="text-text-secondary">
        Comunicação independente e militante.
        <button
          data-open-support
          class="ml-1 font-semibold text-primary hover:underline"
        >
          Apoie nossa luta
        </button>
      </div>

      <a
        href="https://www.instagram.com/comiteabreuelima/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram do Comitê Abreu e Lima"
        class="text-text-secondary hover:text-primary"
      >
        <svg
          class="h-5 w-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M7 2C4.243 2 2 4.243 2 7v10c0 2.757 
               2.243 5 5 5h10c2.757 0 
               5-2.243 5-5V7c0-2.757
               -2.243-5-5-5H7zm10 2
               c1.654 0 3 1.346 3 3v10
               c0 1.654-1.346 3-3 3H7
               c-1.654 0-3-1.346-3-3V7
               c0-1.654 1.346-3 3-3h10zm-5 3
               a5 5 0 100 10 5 5 0 000-10zm0 2
               a3 3 0 110 6 3 3 0 010-6zm4.5-.9
               a1.1 1.1 0 100 2.2 1.1 1.1 0 000-2.2z"
          ></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- =====================
       HEADER PRINCIPAL
       ===================== -->
  <div class="bg-bg">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <img
          src={logo.src}
          width={logo.width}
          height={logo.height}
          alt="Comitê Anti-Imperialista Abreu e Lima"
          class="h-9 md:h-11 w-auto"
        />
        <span class="hidden md:block text-base font-semibold">
          Comitê Anti-Imperialista Abreu e Lima
        </span>
      </div>

      <!-- =====================
           MENU DESKTOP
           ===================== -->
      <nav class="hidden md:flex items-center gap-8 text-base font-semibold">
        <a href="/" class="hover:text-primary">Início</a>
        <a href="/sobre" class="hover:text-primary">Manifesto</a>
        <a href="/atuacao" class="hover:text-primary">Atuação</a>
        <a href="/documentos" class="hover:text-primary">Documentos</a>

        <!-- Galeria Dropdown -->
        <div class="relative">
          <button
            data-gallery-toggle-desktop
            class="flex items-center gap-1 hover:text-primary"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Galeria
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 10.94
                   l3.71-3.71a.75.75 0 111.06 1.06
                   l-4.24 4.24a.75.75 0 01-1.06 0
                   L5.21 8.29a.75.75 0 01.02-1.08z"
                clip-rule="evenodd"></path>
            </svg>
          </button>

          <div
            data-gallery-menu-desktop
            class="absolute left-0 top-full mt-2 w-44
                   rounded-md border border-border bg-bg shadow-lg
                   opacity-0 pointer-events-none translate-y-1
                   transition-all duration-200"
          >
            <a href="/galeria/fotos" class="block px-4 py-2 hover:bg-bg-muted">
              Fotos
            </a>
            <a href="/galeria/videos" class="block px-4 py-2 hover:bg-bg-muted">
              Vídeos
            </a>
          </div>
        </div>

        <a href="/noticias" class="hover:text-primary">Notícias</a>
        <a href="/contato" class="hover:text-primary">Contato</a>
      </nav>

      <!-- =====================
           BOTÃO MOBILE
           ===================== -->
      <button
        data-menu-toggle
        aria-label="Abrir menu"
        aria-expanded="false"
        class="md:hidden relative z-50"
      >
        <svg
          class="h-7 w-7"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            data-icon-menu
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
          <path
            data-icon-close
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Linha identitária -->
  <div class="h-1 bg-primary"></div>

  <!-- =====================
       MENU MOBILE
       ===================== -->
  <nav
    data-mobile-menu
    class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-6
           bg-bg text-lg font-semibold
           -translate-x-full opacity-0 pointer-events-none
           transition-all duration-500 ease-in-out md:hidden"
  >
    <a href="/" class="hover:text-primary">Início</a>
    <a href="/sobre" class="hover:text-primary">Manifesto</a>
    <a href="/atuacao" class="hover:text-primary">Atuação</a>
    <a href="/documentos" class="hover:text-primary">Documentos</a>

    <!-- Galeria Accordion -->
    <div class="flex flex-col items-center gap-2">
      <button
        data-gallery-toggle-mobile
        class="flex items-center gap-1 hover:text-primary"
        aria-expanded="false"
      >
        Galeria
        <svg
          data-gallery-icon-mobile
          class="h-4 w-4 transition-transform"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M5.23 7.21a.75.75 0 011.06.02L10 10.94
               l3.71-3.71a.75.75 0 111.06 1.06
               l-4.24 4.24a.75.75 0 01-1.06 0
               L5.21 8.29a.75.75 0 01.02-1.08z"
            clip-rule="evenodd"></path>
        </svg>
      </button>

      <div data-gallery-menu-mobile class="hidden flex flex-col gap-2 mt-2">
        <a
          href="/galeria/fotos"
          class="block text-sm font-normal text-text-secondary hover:text-primary transition-colors"
        >
          Fotos
        </a>

        <a
          href="/galeria/videos"
          class="block text-sm font-normal text-text-secondary hover:text-primary transition-colors"
        >
          Vídeos
        </a>
      </div>
    </div>

    <a href="/noticias" class="hover:text-primary">Notícias</a>
    <a href="/contato" class="hover:text-primary">Contato</a>
  </nav>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("siteHeader");

    // MENU MOBILE
    const toggle = document.querySelector("[data-menu-toggle]");
    const menu = document.querySelector("[data-mobile-menu]");
    const iconMenu = toggle?.querySelector("[data-icon-menu]");
    const iconClose = toggle?.querySelector("[data-icon-close]");
    let isMenuOpen = false;

    function openMenu() {
      menu.classList.remove(
        "-translate-x-full",
        "opacity-0",
        "pointer-events-none",
      );
      menu.classList.add("translate-x-0", "opacity-100");
      iconMenu.classList.add("hidden");
      iconClose.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      isMenuOpen = true;
    }

    function closeMenu() {
      menu.classList.add(
        "-translate-x-full",
        "opacity-0",
        "pointer-events-none",
      );
      menu.classList.remove("translate-x-0", "opacity-100");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
      document.body.style.overflow = "";
      isMenuOpen = false;
    }

    toggle?.addEventListener("click", () => {
      isMenuOpen ? closeMenu() : openMenu();
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // DROPDOWN DESKTOP
    const gBtn = document.querySelector("[data-gallery-toggle-desktop]");
    const gMenu = document.querySelector("[data-gallery-menu-desktop]");

    if (gBtn && gMenu) {
      const open = () => {
        gMenu.classList.remove(
          "opacity-0",
          "pointer-events-none",
          "translate-y-1",
        );
        gMenu.classList.add("opacity-100", "translate-y-0");
      };
      const close = () => {
        gMenu.classList.add(
          "opacity-0",
          "pointer-events-none",
          "translate-y-1",
        );
        gMenu.classList.remove("opacity-100", "translate-y-0");
      };

      gBtn.addEventListener("mouseenter", open);
      gMenu.addEventListener("mouseenter", open);
      gBtn.addEventListener("mouseleave", () =>
        setTimeout(() => !gMenu.matches(":hover") && close(), 100),
      );
      gMenu.addEventListener("mouseleave", close);
    }

    // ACCORDION MOBILE GALERIA
    const gToggleM = document.querySelector("[data-gallery-toggle-mobile]");
    const gMenuM = document.querySelector("[data-gallery-menu-mobile]");
    const gIconM = document.querySelector("[data-gallery-icon-mobile]");

    gToggleM?.addEventListener("click", () => {
      const open = !gMenuM.classList.contains("hidden");
      gMenuM.classList.toggle("hidden", open);
      gIconM.classList.toggle("rotate-180", !open);
    });

    // HEADER SCROLL
    let lastY = window.scrollY;
    window.addEventListener("scroll", () => {
      const y = window.scrollY;
      if (y > lastY && y > 120 && !isMenuOpen)
        header.classList.add("-translate-y-full");
      if (y < lastY) header.classList.remove("-translate-y-full");
      lastY = y;
    });

    document.addEventListener("mousemove", (e) => {
      if (e.clientY < 60 && !isMenuOpen)
        header.classList.remove("-translate-y-full");
    });
  });
</script>
