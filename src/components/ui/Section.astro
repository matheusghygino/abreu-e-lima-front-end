---
const { title, subtitle } = Astro.props;
---
<section class="py-10">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-2xl">
      {title && <h2 class="text-2xl font-semibold tracking-tight">{title}</h2>}
      {subtitle && <p class="mt-2 text-neutral-600">{subtitle}</p>}
    </div>
    <div class="mt-6">
      <slot />
    </div>
  </div>
</section>
