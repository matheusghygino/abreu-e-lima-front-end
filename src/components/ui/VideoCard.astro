---
import type { Video } from "../../lib/content.mock";
import { ipfsToHttp } from "../../lib/ipfs";

const { video } = Astro.props as { video: Video };
const src = ipfsToHttp(video.ipfsUrl);
const poster = video.posterUrl || "/logo.png";
---
<div class="rounded-2xl border border-neutral-200 p-5">
  <div class="text-sm font-semibold">{video.title}</div>
  <div class="mt-2 text-sm text-neutral-600">{video.description}</div>

  <div class="mt-4 overflow-hidden rounded-xl border border-neutral-200">
    <video controls preload="metadata" poster={poster} class="h-auto w-full bg-neutral-50">
      <source src={src} />
      Seu navegador não suporta reprodução de vídeo.
    </video>
  </div>

  <div class="mt-3 text-xs text-neutral-500 break-all">
    Fonte: {video.ipfsUrl}
  </div>
</div>
