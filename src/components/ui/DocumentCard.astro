---
const { title, file, type, year } = Astro.props;
---

<article class="group flex flex-col gap-2 py-4 border-b border-border last:border-b-0">
  <h3 class="text-base font-medium leading-snug group-hover:text-primary transition">
    {title}
  </h3>

  <div class="flex items-center gap-2 text-sm text-text-secondary">
    <span>{type}</span>
    {year && <span>• {year}</span>}
  </div>

  <a
    href={file}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-1 w-fit text-sm font-medium text-primary hover:underline"
  >
    Baixar documento →
  </a>
</article>
