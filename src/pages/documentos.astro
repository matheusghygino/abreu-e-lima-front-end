---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import DocumentCard from "../components/ui/DocumentCard.astro";
import { getDocumentsBySection } from "../lib/wordpress/documents";

const documents = await getDocumentsBySection();

const sections = [
  {
    key: "resolucoes",
    title: "Resoluções e Regimentos",
    items: documents.resolucoes,
  },
  {
    key: "encontros",
    title: "Encontros e Relatórios",
    items: documents.encontros,
  },
  {
    key: "publicacoes",
    title: "Publicações e Jornal",
    items: documents.publicacoes,
  },
];
---

<BaseLayout
  title="Documentos — Comitê Anti-Imperialista Abreu e Lima"
  description="Resoluções, relatórios, publicações e documentos políticos do Comitê Anti-Imperialista Abreu e Lima."
>
  <main>
    <Section
      title="Documentos do Comitê"
      subtitle="Resoluções, relatórios, publicações e materiais políticos produzidos pelo Comitê."
    >
      {sections
        .filter((section) => section.items.length > 0)
        .map((section) => (
          <div class="mt-12">
            <h2 class="mb-6 text-xl font-semibold">
              {section.title}
            </h2>

            <div class="grid gap-6 md:grid-cols-2">
              {section.items.map((doc) => (
                <DocumentCard
                  title={doc.title}
                  file={doc.fileUrl}
                  type={doc.type}
                />
              ))}
            </div>
          </div>
        ))}
    </Section>
  </main>
</BaseLayout>