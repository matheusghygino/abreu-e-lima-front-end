---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsHeader from "../../components/news/NewsHeader.astro";
import NewsBody from "../../components/news/NewsBody.astro";
import NewsTags from "../../components/news/NewsTags.astro";
import RelatedNews from "../../components/news/RelatedNews.astro";
import { getAllNews, getNewsBySlug } from "../../lib/wordpress/news";

export async function getStaticPaths() {
  const news = await getAllNews();

  return news.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = slug ? await getNewsBySlug(slug) : null;

if (!post) {
  throw new Error(`Notícia não encontrada: ${slug}`);
}
---

<BaseLayout title={`${post.title} — Comitê Anti-Imperialista Abreu e Lima`}>
  <article class="mx-auto max-w-3xl px-4 py-14">
    <NewsHeader post={post} />
    <NewsBody post={post} />
    <NewsTags tags={post.tags} />
    <RelatedNews currentPost={post} />
  </article>
</BaseLayout>